{
  "mcpServers": {
    "veo": {
      "command": "~/.local/bin/mcp-veo-go",
      "env": {
        "MCP_REQUEST_MAX_TOTAL_TIMEOUT": "240000",
        "MCP_SERVER_REQUEST_TIMEOUT": "30000",
        "GENMEDIA_BUCKET": "YOUR_GOOGLE_CLOUD_STORGE_BUCKET",
        "PROJECT_ID": "sre-next"
      }
    },
    "imagen": {
      "command": "~/.local/bin/mcp-nanobanana-go", 
      "env": {
        "MCP_SERVER_REQUEST_TIMEOUT": "55000",
        "GENMEDIA_BUCKET": "YOUR_GOOGLE_CLOUD_STORGE_BUCKET",
        "PROJECT_ID": "sre-next"
      }
    },
    "chirp3-hd": {
      "command": "~/.local/bin/mcp-chirp3-go",
      "env": {
        "MCP_SERVER_REQUEST_TIMEOUT": "55000",
        "GENMEDIA_BUCKET": "YOUR_GOOGLE_CLOUD_STORGE_BUCKET",
        "PROJECT_ID": "sre-next"
      }
    },
    "lyria": {
      "command": "~/.local/bin/mcp-lyria-go",
      "env": {
        "GENMEDIA_BUCKET": "YOUR_GOOGLE_CLOUD_STORGE_BUCKET",
        "PROJECT_ID": "sre-next",
        "MCP_SERVER_REQUEST_TIMEOUT": "55000"
      }
    },
    "avtool": {
      "command": "~/.local/bin/mcp-avtool-go",
      "env": {
        "PROJECT_ID": "sre-next",
        "MCP_SERVER_REQUEST_TIMEOUT": "55000"
      }
    }
  }
}
